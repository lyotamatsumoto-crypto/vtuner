{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "noEmit": true
  },
  "include": [
    "../backend/src/contracts/**/*.ts",
    "../schemas/runtime/**/*.ts",
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./vite.config.ts"
  ]
}
