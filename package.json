{
  "name": "vtuner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "tsx watch backend/src/index.ts",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "typecheck:frontend": "tsc -p frontend/tsconfig.json",
    "typecheck:backend": "tsc -p backend/tsconfig.json --noEmit",
    "typecheck:schemas": "tsc -p schemas/tsconfig.json",
    "check": "npm run typecheck:schemas && npm run typecheck:backend && npm run typecheck:frontend"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
